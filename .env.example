# Copy to `.env` (gitignored) before `docker compose up`:
#   cp .env.example .env        # PowerShell: Copy-Item .env.example .env
#
# Compose auto-reads `.env` from the repo root for ${VAR} substitution.
# These are LOCAL-DEV credentials ONLY — never reuse them in a deployed env.

POSTGRES_USER=promptforge
POSTGRES_PASSWORD=promptforge_local_dev
POSTGRES_DB=promptforge
# --- Host-side overrides (Sprint 28): for running api/worker/scripts directly on the HOST
# (outside Docker). Compose injects in-network URLs (postgres:5432, redis:6379) via its own
# environment: blocks and does NOT read this file into containers, so these apply ONLY to
# host processes. Ports match the unique host mapping in docker-compose.yml: Postgres 5435
# (a native Windows Postgres holds 5433, another local stack holds 5434) and Redis 6381.
# Keep the password below in sync with POSTGRES_PASSWORD above.
PROMPTFORGE_DATABASE_URL=postgresql+psycopg://promptforge:promptforge_local_dev@localhost:5435/promptforge
PROMPTFORGE_REDIS_URL=redis://localhost:6381/0
PROMPTFORGE_CELERY_BROKER_URL=redis://localhost:6381/1
PROMPTFORGE_CELERY_RESULT_BACKEND=redis://localhost:6381/2
